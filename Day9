#include <stdio.h>

#define V 4
#define E 12
#define INF 9999

struct Edge {
    int s, d, w;
};

int main() {
    struct Edge e[E] = {
        {0,1,10}, {1,0,10},
        {0,2,15}, {2,0,15},
        {0,3,10}, {3,0,10},
        {1,2,35}, {2,1,35},
        {1,3,25}, {3,1,25},
        {2,3,30}, {3,2,30}
    };

    int dis[V] = {0, INF, INF, INF};
    int i, j;

    for (i = 1; i < V; i++) {
        for (j = 0; j < E; j++) {
            int u = e[j].s;
            int v = e[j].d;
            int w = e[j].w;

            if (dis[u] != INF && dis[u] + w < dis[v])
                dis[v] = dis[u] + w;
        }
    }

    printf("Shortest distance from A:\n");
    printf("A = %d\n", dis[0]);
    printf("B = %d\n", dis[1]);
    printf("C = %d\n", dis[2]);
    printf("D = %d\n", dis[3]);

    return 0;
}
