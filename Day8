#include <stdio.h>

#define n 4
#define INF 9999

int g[n][n] = {
    {0,10,15,10},
    {10,0,35,25},
    {15,35,0,30},
    {10,25,30,0}
};

int dp[20][20];

int tsp(int m, int p) {
    if (m == (1 << n) - 1)
        return g[p][0];

    if (dp[m][p] != -1)
        return dp[m][p];

    int ans = INF, i, c;

    for (i = 0; i < n; i++) {
        if (!(m & (1 << i))) {
            c = g[p][i] + tsp(m | (1 << i), i);
            if (c < ans)
                ans = c;
        }
    }

    return dp[m][p] = ans;
}

int main() {
    int i, j;

    for (i = 0; i < 20; i++)
        for (j = 0; j < 20; j++)
            dp[i][j] = -1;

    printf("Minimum cost = %d", tsp(1, 0));

    return 0;
}
